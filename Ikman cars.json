      "parameters": {
        "jsCode": "// Input: merged items from Merge (new rows + existing sheet rows), each has _source\nconst items = $input.all();\nconst existingIds = new Set();\nconst newRows = [];\nfor (let i = 0; i < items.length; i++) {\n  const j = items[i].json;\n  const src = j && j._source;\n  const id = j && (j.id || j.Id);\n  if (src === 'existing' && id != null && id !== '') existingIds.add(String(id));\n  if (src === 'new') newRows.push(items[i]);\n}\nconst out = [];\nfor (let k = 0; k < newRows.length; k++) {\n  const j = newRows[k].json;\n  const id = j && j.id;\n  if (id != null && id !== '' && !existingIds.has(String(id))) {\n    const copy = Object.assign({}, j);\n    delete copy._source;\n    out.push({ json: copy });\n    existingIds.add(String(id));\n  }\n}\nreturn out;"
      },
