      "parameters": {
        "jsCode": "// One item per page; get HTML from body/data and strip tags for extractor\nfor (const item of $input.all()) {\n  const raw = item.json.body || item.json.data || item.json;\n  const html = typeof raw === 'string' ? raw : JSON.stringify(raw);\n  item.json.cleanText = html.replace(/<[^>]*>/g, ' ').replace(/\\s+/g, ' ').trim();\n}\nreturn $input.all();"
