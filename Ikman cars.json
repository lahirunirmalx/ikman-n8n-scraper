    {
      "parameters": {
        "jsCode": "// Aggregate all pages from Information Extractor; output one flat row per listing\nconst items = $input.all();\nconst rows = [];\n\nfunction toRow(ad) {\n  if (!ad || typeof ad !== 'object') return null;\n  const cat = ad.category || {};\n  const img = ad.images || {};\n  const ids = img.ids || [];\n  return {\n    id: ad.id,\n    slug: ad.slug,\n    title: ad.title,\n    description: ad.description,\n    details: ad.details,\n    subtitle: ad.subtitle || '',\n    imgUrl: ad.imgUrl,\n    price: ad.price,\n    discount: ad.discount,\n    mrp: ad.mrp,\n    isMember: ad.isMember,\n    isAuthDealer: ad.isAuthDealer,\n    isFeaturedAd: ad.isFeaturedAd,\n    membershipLevel: ad.membershipLevel || '',\n    shopName: ad.shopName || '',\n    timeStamp: ad.timeStamp,\n    lastBumpUpDate: ad.lastBumpUpDate,\n    categoryId: cat.id,\n    categoryName: cat.name || '',\n    isVerified: ad.isVerified,\n    isJobAd: ad.isJobAd,\n    location: ad.location,\n    adType: ad.adType,\n    isTopAd: ad.isTopAd,\n    isUrgentAd: ad.isUrgentAd,\n    imageCount: ids.length\n  };\n}\n\nfunction toList(j) {\n  if (Array.isArray(j)) return j;\n  if (j && Array.isArray(j.output)) return j.output;\n  if (j && typeof j.result !== 'undefined') {\n    const r = j.result;\n    if (Array.isArray(r)) return r;\n    if (typeof r === 'string') { try { const a = JSON.parse(r); return Array.isArray(a) ? a : [a]; } catch (e) { return []; } }\n    if (r && typeof r === 'object') return [r];\n  }\n  if (j && typeof j.id === 'string') return [j];\n  return [];\n}\n\nfor (let i = 0; i < items.length; i++) {\n  const list = toList(items[i].json);\n  for (let k = 0; k < list.length; k++) {\n    const row = toRow(list[k]);\n    if (row && row.id) rows.push({ json: row });\n  }\n}\n\nreturn rows.length ? rows : [];"
      },
