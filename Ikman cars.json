    {
      "parameters": {
        "jsCode": "// User provides baseUrl in 'Set base URL'; paginate 10 pages with ikman query params\nconst baseUrl = ($input.first().json.baseUrl || 'https://ikman.lk/en/ads/sri-lanka/motorbikes-scooters').toString().trim();\nconst sep = baseUrl.indexOf('?') >= 0 ? '&' : '?';\nconst query = 'sort=date&order=desc&buy_now=0&urgent=0&page=';\nconst pages = 10;\nconst out = [];\nfor (let p = 1; p <= pages; p++) {\n  out.push({ json: { baseUrl: baseUrl, page: p, url: baseUrl + sep + query + p } });\n}\nreturn out;"
      },
